{
  "name": "ruigetest",
  "version": "1.0.0",
  "description": "一个完整的网页制作与部署示例项目",
  "main": "index.html",
  "scripts": {
    "start": "http-server -p 8080",
    "dev": "python3 -m http.server 8000",
    "test": "echo \"打开浏览器访问 http://localhost:8080\" && npm start",
    "deploy:github": "./deploy.sh 2",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod",
    "deploy:all": "./deploy.sh 5",
    "build": "echo \"构建静态网站...\" && npm run build:css && npm run build:js",
    "build:css": "npx cleancss -o style.min.css style.css",
    "build:js": "npx uglify-js script.js -o script.min.js --compress --mangle",
    "lint": "npx eslint . --ext .js --fix || echo \"ESLint未安装，运行 'npm install --save-dev eslint' 安装\"",
    "format": "npx prettier --write . || echo \"Prettier未安装，运行 'npm install --save-dev prettier' 安装\""
  },
  "keywords": [
    "website",
    "tutorial",
    "deployment",
    "html",
    "css",
    "javascript",
    "beginner"
  ],
  "author": "RuigeTest",
  "license": "MIT",
  "devDependencies": {
    "http-server": "^14.1.1",
    "clean-css-cli": "^5.3.3",
    "uglify-js": "^3.17.4"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/ruigetest.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/ruigetest/issues"
  },
  "homepage": "https://your-username.github.io/ruigetest",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}